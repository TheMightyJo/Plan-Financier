rules_version = '2';

// L'application Plan Financier n'utilise actuellement que Firebase Auth.
// Aucune écriture Firestore n'est attendue côté client : on refuse tout par défaut.
// Lorsque Firestore sera utilisé, ouvrir explicitement les chemins nécessaires
// avec une condition `request.auth.uid == userId` (ou équivalent).
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
