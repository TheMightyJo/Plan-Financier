rules_version = '2';

// Aucun upload utilisateur n'est exposé via Firebase Storage pour le moment.
// Tout est refusé par défaut ; ouvrir uniquement les chemins nécessaires lors
// d'un futur usage, en exigeant `request.auth != null` au minimum.
service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
